}

#articleQrCodeModal .form-range::-moz-range-thumb {
  background: #3052eb;
  border: none;
  border-radius: 50%;
  cursor: pointer;
}

#articleQrCodeModal .badge {
  font-size: 0.7em;
}

#articleQrCodeModal .btn-outline-primary:hover,
#articleQrCodeModal .btn-outline-info:hover {
  transform: translateY(-1px);
