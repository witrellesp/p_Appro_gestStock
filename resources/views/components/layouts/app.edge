          <li class="nav-header">Emprunts</li>
          <li>
            <a href="/borrow">
              <i class="fa fa-shopping-basket"></i> <span>Liste</span>
            </a>
          </li>
        </ul>

        <!-- Menu dynamique catégories (stub por ahora) -->
        <div id="mnuNavMateriel">
          @if(state.menuHtml)
          {{{ state.menuHtml }}}
          @endif
        </div>



      </div>
    </div>
    <!-- end #sidebar -->

    <!-- begin #content -->
    <div id="content" class="content">
      
      <!-- Flash messages (stub) -->
      @if(state.flash)
      <div class="alert alert-{{ state.flash.type ?? 'info' }} fade in" role="alert">
        <p class="font-weight-600">{{ state.flash.title ?? '' }}</p>
        <ul>
          @each(error in state.flash.messages)
          <li class="p-l-10">{{ error }}</li>
          @endeach
        </ul>
      </div>
      @endif

    
    </div>
    <!-- end #content -->

