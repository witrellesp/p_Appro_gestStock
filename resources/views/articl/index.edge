            <pre>{{ JSON.stringify(articles, null, 2) }}</pre> --}}



          </i>
        </div>



      </li>
    </div>

    <!-- on vérifie si la clé du produit existe dans le tableau articles c'est à dire si il ya des articles pour ce produit 
									     si pas de clé ... alors on affiche pas de vignette -->
    @if( articles.filter(a => a.fkProduct === p.id))

    <div id="collapse_{{p.id}}" class="collapse show" data-parent="#accordion">
      <div class="card-body">

        <div class="row">


        @each(article in articles.filter(a => a.fkProduct === p.id))
          


          <!-- begin shadow-card -->
          <div class="shadow-card  m-r-10 m-b-10" style="width: 12rem">

            <div class="widget-list widget-list-rounded" data-id="widget">


              <!-- begin widget-list-item -->
              <div id="box_article" class="widget-list-item">


                <div class="widget-list-media bg-none">


                  @if(article.isBorrowed )
                  <i id="c_{{article.id}}" class="fas fa-lg fa-fw m-r-10 fa-times fa-2x text-red"
                    style="line-height: 30px"></i>

                  @else

                  <i id="c_{{article.id}}" class="fas fa-lg fa-fw m-r-10 fa-check fa-2x text-green"
                    style="line-height: 30px"></i>

                  @endif
                </div>



                <div class="widget-list-content">
                  <a href="#" data-toggle="modal" onclick="setArticleView({{article.id}})">
