}

#articleQrCodeModal .card {
  transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
}

#articleQrCodeModal .card:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1) !important;
