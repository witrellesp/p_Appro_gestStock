                      {{ article.label}}
                    </h4>
                  </a>
                  <p class="widget-list-desc">
                    {{ article.chest.room.name}} / {{ article.chest.name}}
                  </p>
                  <p class="widget-list-desc text-warning">

                    @if(article.isBorrowed)
                    {{article.user.firstname}} {{article.user.name}}
                    @else

                    @end

                  </p>
                </div>


              </div>


              <!-- begin boutons icones -->
              <div class="widget-list-item bg-grey-transparent-5 text-center">
                <!-- end widget-list-item -->
                <span><a href="#" class="text-grey-darker" data-toggle="modal"
                    onclick="setArticleQrCodeView({{article.id}})">
                    <i class="fas fa-qrcode  width-30 height-30 f-s-20 text-center " style="line-height: 30px"></i>
                </span></a>

                <!-- il faut être connecté pour emprunter ou restitué un article -->

