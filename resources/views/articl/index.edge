                      style="line-height: 30px"></i>
                    @else

                    {{-- emprunter --}}
                    <i id="i_{{article.id}}"
                      class="fas fa-sign-out-alt fa-rotate-270 fa-2x width-30 height-30 f-s-20 text-center"
                      style="line-height: 30px"></i>
