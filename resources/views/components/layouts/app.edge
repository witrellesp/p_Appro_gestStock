<body>
  
  <!-- begin #page-loader -->
  <div id="page-loader" class="fade show"><span class="spinner"></span></div>
  <!-- end #page-loader -->

  <!-- begin #page-container -->
  <div id="page-container" class="fade page-sidebar-fixed page-header-fixed">

    <!-- begin #header -->
    <div id="header" class="header navbar-inverse">

      <!-- begin navbar-header -->
      <div class="navbar-header">
        <a href="/" class="navbar-brand">
          <img src="/img/logo-GestStock.png" alt="logoGestStock">
          <b class="text-orange">GestStockInf</b> <span class="font_etml">ETML</span>
          <span class="small"> - Informatique</span>
        </a>

        <button type="button" class="navbar-toggle" data-click="sidebar-toggled">
          <span class="icon-bar"></span>
          <span class="icon-bar"></span>
          <span class="icon-bar"></span>
        </button>
      </div>
      <!-- end navbar-header -->

      <!-- menu d'entête -->
      <ul class="navbar-nav navbar-right">
        <!-- AUTH STUB (tu lo remplazas cuando implementes auth) -->
        @if(state.isAuthenticated)
        <li>
          <a href="/logout">
            <i class="ion ion-md-log-out fa-2x fa-fw pull-left m-r-5 text-white-light"></i>
            <span class="d-none d-md-inline">Déconnexion</span>
          </a>
        </li>
        @else
        <li class="dropdown navbar-user">
          <a href="#" class="dropdown-toggle" data-toggle="dropdown">
            <i class="ion ion-md-log-in fa-2x fa-fw pull-left m-r-5 text-white-light"></i>
            <span class="d-none d-md-inline">Connexion</span> <b class="caret"></b>
          </a>

          <div class="dropdown-menu dropdown-menu-right m-t-10">
            <!-- Por ahora no implementamos login, pero dejamos el HTML -->
            <form id="frm-login" class="form" action="/login" method="POST">
              <div class="card-body text-center p-0">
                <div class="form-group m-10">
                  <input type="text" name="login" class="form-control form-control-sm" id="login"
                    placeholder="Identifiant">
                  <span id="error_login" class="text-danger"></span>
                </div>
                <div class="form-group m-10">
                  <input type="password" name="password" class="form-control form-control-sm" id="password"
                    placeholder="Mot de Passe">
                  <span id="error_password" class="text-danger"></span>
                </div>

                <button type="button" class="btn btn-sm btn-success m-r-5" onclick="loginUser()">Connection</button>
              </div>
            </form>
          </div>
        </li>
        @endif
      </ul>
      <!-- fin menu d'entête -->

    </div>
    <!-- end #header -->

    <!-- begin #sidebar -->
    <div id="sidebar" class="sidebar">
      <div data-scrollbar="true" data-height="100%">

        <!-- Profil user (stub) -->
        @if(state.isAuthenticated)
        <ul class="nav">
          <li class="nav-profile">
            <div class="row">
              <div class="col-sm-4">
                <div class="user-pic">
                  <img src="{{ state.userPhoto ?? '/img/no-photo.jpg' }}" alt="User picture" />
                </div>
              </div>

              <div class="col-sm-8">
                <div class="row f-s-14">{{ state.userId ?? '' }}</div>
                <div class="row text-orange">{{ state.userFullName ?? '' }}</div>
                <div class="row">
                  <div class="col-sm-3 p-t-5">
                    <div class="box">
                      <div class="notifications">
                        <i class="fa fa-bell"></i>
                        <div id="contenu">
                          <span id="usrNbBorrow">0</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          </li>
        </ul>
        @endif

        <!-- Navigation -->
        <ul class="nav">
          <li>
            <a href="javascript:;" class="sidebar-minify-btn" data-click="sidebar-minify">
              <i class="fa fa-angle-double-left"></i>
            </a>
          </li>

          <!-- Gestion (solo admin) -->
          @if(state.isAdministrator)
          <li class="nav-header">Gestion</li>
          <li>
            <a href="/gestion">
              <i class="fa fa-calendar"></i> <span>Entités de base</span>
            </a>
          </li>
