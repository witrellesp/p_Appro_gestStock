{{-- @if(products !=== 0)

@end --}}



@each(p in products)
<div id="accordion" class="card-accordion">
  <div class="card">

    <div class="card-header bg-grey-light text-seondary pointer-cursor" style="height: 6rem;" data-toggle="collapse"
      data-target="#collapse_{{p.id}}">

      <li class="media media-sm">
        <a href="javascript:;" class="pull-left">
          <img src="<?php echo $this->html()->imgCheck(IMAGES_URL_PRODUCTS.$product->prod_picture().'.jpg'); ?>" alt=""
            class="media-object ">
        </a>
        <div class="media-body">
          <a href="javascript:;">
            <h4 class="media-heading">{{ p.name}}</h4>
          </a>
          <p class="m-b-5">
            {{p.description}}
          </p>
          <i class="fa fa-hand-o-right" aria-hidden="true"></i>
          <i class="text-muted">Nombre d'articles :

            <!-- chercher les produits existant dans l'article -->
            {{ articles.filter(a => a.fkProduct === p.id).length }}

