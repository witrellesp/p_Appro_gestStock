    transform: translate(0, -50px) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translate(0, 0) scale(1);
  }
}

/* Responsive */
@media (max-width: 768px) {
  #articleQrCodeModal .modal-dialog {
    margin: 0.5rem;
    max-width: calc(100% - 1rem);
